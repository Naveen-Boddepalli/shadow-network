# AI Engine config
AI_PORT=8000

# IPFS — same node the backend uses
IPFS_GATEWAY=http://127.0.0.1:8080

# Models — downloaded automatically from HuggingFace on first run
# These are free, no API key needed
SUMMARIZATION_MODEL=facebook/bart-large-cnn
QA_MODEL=deepset/roberta-base-squad2

# Controls how much text is sent to models (tokens)
MAX_INPUT_TOKENS=1024
SUMMARY_MAX_LENGTH=200
SUMMARY_MIN_LENGTH=50

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# MongoDB Atlas — used for persistent vector search storage
# (replaces ephemeral FAISS files that were wiped on Render free tier restarts)
MONGO_URI=mongodb+srv://<user>:<password>@shadow-network.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=shadow-network
