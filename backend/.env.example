# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/shadow-network

# IPFS (Kubo local node - default)
IPFS_HOST=127.0.0.1
IPFS_PORT=5001
IPFS_PROTOCOL=http

# Phase 4: Semantic Search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Security ──────────────────────────────────────────────────────────────────

# JWT — sign and verify access tokens (use a long random string in production)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_in_production

# Shared API secret — clients POST this to /api/v1/auth/token to receive a JWT
API_SECRET=change_me_to_a_secure_api_secret_in_production

# CORS — comma-separated list of allowed frontend origins (exact match, no wildcards)
# Example: https://shadow-network.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
