# Frontend .env
# The React dev server proxies /api/* to this address (also set in package.json proxy)
VITE_API_URL=http://localhost:5000/api/v1

# P2P mode — when true, uses Helia (browser IPFS) instead of backend
# Set to false to use the centralized backend (easier for development)
VITE_P2P_MODE=false
